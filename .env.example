# Copy to .env for local non-CLI runs, or set these in your host's env config.
# When running `shopify app dev`, the CLI injects SHOPIFY_API_KEY/SECRET/SCOPES
# and the tunnel URL for you — you do NOT need this file for local dev.

# --- Shopify app credentials (from `shopify app env show` on the PROD app) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public origin where the app is hosted, including protocol. Used for OAuth
# redirects and App Bridge. Must match application_url in your prod .toml.
SHOPIFY_APP_URL=https://your-app.example.com

# Optional with Shopify-managed install; otherwise comma-separated.
SCOPES=write_products

# --- Database (Postgres) ---
# Prisma reads this (see prisma/schema.prisma). Session tokens live here, so it
# MUST be a persistent database — not the old file-based SQLite.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Port the server listens on. Match EXPOSE in the Dockerfile. Defaults to 3000.
PORT=3000
