# Example PRODUCTION app config.
#
# Recommended: don't hand-edit this. Instead create a SEPARATE app in the Dev
# Dashboard for production, then run `shopify app config link` and pick it — the
# CLI generates a real `shopify.app.<name>.toml` with the correct client_id.
# This file just shows what the result should look like. Copy it to
# `shopify.app.production.toml` and fill in the blanks if you'd rather do it by hand.
#
# Keep this separate from the dev config so deploying prod never disturbs `shopify app dev`.

client_id = "REPLACE_WITH_PRODUCTION_APP_CLIENT_ID"
application_url = "https://your-app.example.com"
embedded = true
name = "sample_collection_sources"

[access_scopes]
# read is implied by write_products; needed for the collection conditions source APIs.
scopes = "write_products,write_metaobjects,write_metaobject_definitions"

[auth]
redirect_urls = [ "https://your-app.example.com/auth/callback" ]

[webhooks]
api_version = "2026-07"

  [[webhooks.subscriptions]]
  uri = "/webhooks/app/uninstalled"
  topics = [ "app/uninstalled" ]

  [[webhooks.subscriptions]]
  uri = "/webhooks/app/scopes_update"
  topics = [ "app/scopes_update" ]

[build]
include_config_on_deploy = true
# Turn OFF auto URL updates for prod so a local `shopify app dev` can't overwrite
# the production application_url.
automatically_update_urls_on_dev = false
